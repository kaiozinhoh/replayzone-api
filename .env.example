# ============================================
# replayzone-api - Variáveis de ambiente
# ============================================
# Copie para .env e preencha. No EasyPanel, configure em Variables do serviço.

# Servidor
PORT=3000

# Banco de dados MySQL
DB_HOST=db.replayzone.com.br
DB_USER=replayzone
DB_PASSWORD=sua_senha
DB_NAME=replayzone

# API Key (header x-api-key)
API_KEY=sua_api_key_secreta

# Opcional: pasta para arquivos estáticos /videos/logos (deixe em branco para desabilitar)
# STATIC_VIDEOS_PATH=/home/ftp/videos/logos
